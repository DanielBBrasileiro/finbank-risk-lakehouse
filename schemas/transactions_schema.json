{
  "name": "transactions",
  "required_columns": [
    "transaction_id",
    "customer_id",
    "account_id",
    "transaction_date",
    "channel",
    "transaction_type",
    "amount",
    "is_suspicious"
  ],
  "not_null": [
    "transaction_id",
    "customer_id",
    "account_id",
    "transaction_date",
    "amount"
  ],
  "unique": [
    "transaction_id"
  ],
  "types": {"amount": "number", "is_suspicious": "boolean"},
  "ranges": {"amount": {"min": 0}},
  "accepted_values": {
    "channel": ["PIX", "CARD", "ATM", "BRANCH", "TED", "APP"],
    "transaction_type": ["DEBIT", "CREDIT", "TRANSFER", "PAYMENT", "WITHDRAWAL"]
  }
}
