{
  "name": "customers",
  "required_columns": [
    "customer_id",
    "customer_name",
    "document_type",
    "segment",
    "state",
    "created_at",
    "internal_score"
  ],
  "not_null": [
    "customer_id",
    "segment",
    "state",
    "created_at"
  ],
  "unique": [
    "customer_id"
  ],
  "types": {"internal_score": "integer"},
  "ranges": {"internal_score": {"min": 0, "max": 1000}},
  "accepted_values": {
    "document_type": ["CPF", "CNPJ"],
    "segment": ["PF_LOW_INCOME", "PF_MASS", "PF_AFFLUENT", "PJ_SMALL", "PJ_MID"]
  }
}
