{
  "name": "loans",
  "required_columns": [
    "loan_id",
    "customer_id",
    "product_type",
    "origination_date",
    "maturity_date",
    "principal_amount",
    "outstanding_balance",
    "interest_rate",
    "days_past_due",
    "risk_rating"
  ],
  "not_null": [
    "loan_id",
    "customer_id",
    "product_type",
    "origination_date",
    "maturity_date",
    "principal_amount",
    "outstanding_balance",
    "days_past_due",
    "risk_rating"
  ],
  "unique": [
    "loan_id"
  ],
  "types": {
    "principal_amount": "number",
    "outstanding_balance": "number",
    "interest_rate": "number",
    "days_past_due": "integer"
  },
  "ranges": {
    "principal_amount": {"min": 0},
    "outstanding_balance": {"min": 0},
    "interest_rate": {"min": 0},
    "days_past_due": {"min": 0}
  },
  "accepted_values": {
    "product_type": ["PERSONAL_LOAN", "AUTO_LOAN", "MORTGAGE", "WORKING_CAPITAL", "CREDIT_CARD"],
    "risk_rating": ["AA", "A", "B", "C", "D", "E"]
  }
}
