# Local warehouse
DB_TARGET=duckdb
DBT_TARGET=duckdb
DBT_SCHEMA=analytics
DUCKDB_PATH=data/warehouse.duckdb

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=finbank
POSTGRES_USER=finbank
POSTGRES_PASSWORD=finbank
AI_POSTGRES_USER=finbank_reader
AI_POSTGRES_PASSWORD=finbank_reader

# Object storage (optional for the local demo)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Vector storage (optional for the local demo)
QDRANT_URL=http://localhost:6333

# Analytical copilot
AI_DEMO_MODE=1
AI_AUDIT_PATH=data/ai_audit/copilot_audit.jsonl
LLM_PROVIDER=offline

# Optional LLM providers
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_EMBEDDING_MODEL=text-embedding-004
OPENAI_API_KEY=

# Optional cloud integrations
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=FINBANK
SNOWFLAKE_SCHEMA=ANALYTICS

AWS_REGION=us-east-1
AWS_PROFILE=
S3_BUCKET=finbank-risk-lake

DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_CLUSTER_ID=

# Optional streaming
KAFKA_BROKER=localhost:9092
KAFKA_GROUP_ID=finbank-suspicious-summary-v1
KAFKA_AUTO_OFFSET_RESET=earliest
STREAMING_DB_RETRIES=5
STREAMING_DB_RETRY_DELAY_SECONDS=0.05
